{
  "name": "research-exec",
  "version": "1.0.0",
  "description": "Research & Implementation Hub - Transform research into actionable frameworks",
  "main": "index.js",
  "scripts": {
    "data:collect": "gh repo list --json name,description,visibility,isPrivate,updatedAt,primaryLanguage --limit 200 > data/raw-repos.json",
    "data:analyze": "node utils/analyze-data.js",
    "data:process": "node utils/process-data.js",
    "analyze": "npm run data:collect && npm run data:analyze",
    "setup": "node utils/setup.js",
    "clean": "rm -rf data/raw-repos.json data/repos-analysis.md",
    "check-links": "node utils/check-readme-links.js",
    "check-all-links": "node utils/check-links.js"
  },
  "keywords": [
    "research-methodology",
    "implementation-frameworks", 
    "portfolio-analysis", 
    "documentation-strategy",
    "research-transformation",
    "github",
    "methodology",
    "project-management"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "markdown-link-check": "^3.11.2"
  }
}
