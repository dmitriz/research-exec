{
  "name": "research-exec",
  "version": "1.0.0",
  "description": "Documentation & Strategy Hub for GitHub Portfolio Analysis",
  "main": "index.js",
  "scripts": {
    "data:collect": "gh repo list --json name,description,visibility,isPrivate,updatedAt,primaryLanguage --limit 200 > data/raw-repos.json",
    "data:analyze": "node utils/analyze-data.js",
    "analyze": "npm run data:collect && npm run data:analyze",
    "setup": "npm run analyze",
    "clean": "rm -rf data/raw-repos.json data/repos-analysis.md"
  },
  "keywords": [
    "documentation",
    "strategy",
    "portfolio-analysis", 
    "github",
    "methodology",
    "project-management"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "markdown-link-check": "^3.11.2"
  }
}
